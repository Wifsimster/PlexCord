{
    "name": "plexcord",
    "version": "4.3.0",
    "private": true,
    "type": "module",
    "scripts": {
        "clean-dist": "rm -rf dist && mkdir dist && touch dist/index.html",
        "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .eslintignore",
        "dev": "vite",
        "dev-build": "vite build -m development --minify false --logLevel info",
        "dev-build-watch": "vite build --watch --emptyOutDir false -m development --minify false --logLevel info",
        "preview": "vite preview",
        "build": "vite build",
        "build-watch": "vite build --watch --emptyOutDir false",
        "vite": "vite",
        "test": "vitest run",
        "test:watch": "vitest",
        "prepare": "cd .. && husky frontend/.husky"
    },
    "dependencies": {
        "@primeuix/themes": "^2.0.3",
        "chart.js": "4.5.1",
        "pinia": "^3.0.4",
        "primeicons": "^7.0.0",
        "primevue": "^4.5.5",
        "tailwindcss-primeui": "^0.6.1",
        "vue": "^3.5.32",
        "vue-router": "^5.0.4"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.0.0",
        "@commitlint/config-conventional": "^19.0.0",
        "@primevue/auto-import-resolver": "^4.5.5",
        "@rushstack/eslint-patch": "^1.16.1",
        "@semantic-release/changelog": "^6.0.0",
        "@semantic-release/commit-analyzer": "^13.0.0",
        "@semantic-release/git": "^10.0.0",
        "@semantic-release/github": "^11.0.0",
        "@semantic-release/npm": "^12.0.0",
        "@semantic-release/release-notes-generator": "^14.0.0",
        "@tailwindcss/vite": "^4.2.2",
        "@vitejs/plugin-vue": "^6.0.6",
        "@vue/eslint-config-prettier": "^10.2.0",
        "eslint": "^10.2.1",
        "eslint-plugin-vue": "^10.8.0",
        "husky": "^9.0.0",
        "prettier": "^3.8.3",
        "sass": "^1.99.0",
        "semantic-release": "^24.0.0",
        "tailwindcss": "^4.2.2",
        "unplugin-vue-components": "^32.0.0",
        "@vue/test-utils": "^2.4.6",
        "jsdom": "^29.0.2",
        "vite": "^8.0.9",
        "vitest": "^4.1.4"
    },
    "author": ""
}
